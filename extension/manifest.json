{
    "manifest_version": 3,
    "name": "JobNova - AI Career Agent",
    "version": "1.0",
    "description": "Your AI career agent for LinkedIn. Analyze recruiter messages, research companies, and draft perfect replies.",
    "permissions": [
        "activeTab",
        "storage",
        "scripting"
    ],
    "host_permissions": [
        "http://localhost:8000/*",
        "*://*.linkedin.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.linkedin.com/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "assistant.css"
            ]
        }
    ],
    "options_ui": {
        "page": "options.html",
        "open_in_tab": false
    }
}