# ReboundIQ Environment (copy to .env for local, never commit secrets)
# See AI_PROVIDER_GUIDE.md and LOCAL_AI_SETUP.md

# === Core DB / Infra ===
DATABASE_URL=postgresql+asyncpg://reboundiq:reboundiq_dev@localhost:5432/reboundiq
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# === AI (Local-first default) ===
AI_PROVIDER=ollama
AI_CHAT_MODEL=llama3.2:1b
AI_EMBEDDING_MODEL=nomic-embed-text
AI_BASE_URL=http://localhost:11434
AI_FALLBACK_PROVIDER=
AI_FALLBACK_MODEL=
ENABLE_EXTERNAL_AI=false

# Optional external (only if ENABLE_EXTERNAL_AI=true + user consent recorded)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=...
# GROQ_API_KEY=...
# LITELLM_PROXY_URL=...

# === Storage ===
STORAGE_BACKEND=local   # local | s3
STORAGE_LOCAL_ROOT=./storage
# S3_ (for minio or real)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=reboundiq
S3_SECRET_KEY=reboundiqminio123
S3_BUCKET=reboundiq-dev
S3_REGION=us-east-1

# === Auth / Security ===
JWT_SECRET=change-this-to-a-long-random-secret-in-prod
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ENCRYPTION_KEY=change-this-to-32-byte-base64url-fernet-key

# === Hindsight (optional, disabled by default) ===
HINDSIGHT_ENABLED=false
HINDSIGHT_BASE_URL=
HINDSIGHT_API_KEY=

# === Observability / Misc ===
LOG_LEVEL=INFO
ENV=development
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# === Feature Flags (for rollout) ===
FEATURE_DEEP_AGENT=true
FEATURE_HINDSIGHT_MEMORY=false
FEATURE_VISA_MODE=true
